{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "index.html",
          "orders.html",
          "styles.css",
          "script.js",
          "robots.txt",
          "sitemap.xml",
          "manifest.json",
          "sw.js",
          "assets/**",
          "db/**",
          "admin/**"
        ]
      }
    }
  ],
  "routes": [
    { "handle": "filesystem" },
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ]
}
