# Example environment variables for the payment server
PORT=3000
# Merchant UPI VPA (e.g. payee@upi)
SHOP_UPI_ID=merchant@upi
SHOP_NAME=Jagdamb Laundry & Drycleaners
# Optional fallback static QR image path
FALLBACK_QR=/assets/QR.jpeg

# Decentro provider configuration (optional)
DECENTRO_BASE_URL=https://api.decentro.co
DECENTRO_API_KEY=YOUR_DECENTRO_API_KEY
# If Decentro supports webhook signature verification, set the secret and header name
DECENTRO_WEBHOOK_SECRET=your_webhook_secret
DECENTRO_WEBHOOK_HEADER=x-decentro-signature
# Public URL where provider can call webhook (use ngrok or a public domain in production)
PUBLIC_BASE_URL=http://localhost:3000
